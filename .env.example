# ── Azure OpenAI (Switzerland North) ────────────────────────────
# Get these from: Azure Portal → your OpenAI resource → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── Ollama (offline / no Azure key) ─────────────────────────────
# Set OLLAMA_MODE=true to bypass Azure and use local Ollama instead
# Requires: ollama pull llama3.2 running on your machine
OLLAMA_MODE=false
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# ── Database ─────────────────────────────────────────────────────
DB_USER=ticketai
DB_PASSWORD=ticketai

# ── Notifications (optional — leave blank for log-only mock mode) ─
SLACK_WEBHOOK_URL=
PAGERDUTY_WEBHOOK_URL=
